<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
  <FileVersion major="1" minor="6" />
  <Project>
    <Option title="WidgetLauncherCpp" />
    <Option pch_mode="2" />
    <Option compiler="gcc" />
    <Build>
      <Target title="Debug">
        <Option output="bin\Debug\WidgetLauncherCpp.exe" prefix_auto="1" extension_auto="1" />
        <Option object_output="obj\Debug\" />
        <Option type="0" />
        <Option compiler="gcc" />
        <Compiler>
          <Add option="-std=c++17" />
          <Add option="-Wall" />
          <Add option="-g" />
        </Compiler>
        <Linker>
          <Add option="-mwindows" />
          <Add library="comctl32" />
          <Add library="uxtheme" />
        </Linker>
      </Target>
      <Target title="Release">
        <Option output="bin\Release\WidgetLauncherCpp.exe" prefix_auto="1" extension_auto="1" />
        <Option object_output="obj\Release\" />
        <Option type="0" />
        <Option compiler="gcc" />
        <Compiler>
          <Add option="-std=c++17" />
          <Add option="-O2" />
        </Compiler>
        <Linker>
          <Add option="-mwindows" />
          <Add library="comctl32" />
          <Add library="uxtheme" />
        </Linker>
      </Target>
    </Build>
    <Compiler>
      <Add option="-std=c++17" />
    </Compiler>
    <Unit filename="main.cpp" />
    <Extensions>
      <code_completion />
      <debugger />
    </Extensions>
  </Project>
</CodeBlocks_project_file>
